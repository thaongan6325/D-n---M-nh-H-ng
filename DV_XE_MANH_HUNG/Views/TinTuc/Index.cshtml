@model IEnumerable<Vivu_Xe.Models.TinTuc>

@{
    ViewData["Title"] = "Tin tức & Cẩm nang";

    // Ép kiểu Model thành List để dễ xử lý chia bài
    var allNews = Model?.ToList() ?? new List<Vivu_Xe.Models.TinTuc>();

    // Điều kiện hiện Tin nổi bật: Đang ở trang "Tất cả" (CurrentCategory null) và phải có từ 3 bài trở lên
    bool isShowFeatured = ViewBag.CurrentCategory == null && allNews.Count >= 3;
}

<link rel="stylesheet" href="~/css/category.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/news.css" asp-append-version="true" />

<section class="news-header-section">
    <div class="custom-container">
        <h1 class="news-title">@ViewData["Title"]</h1>

        <nav class="breadcrumb-nav">
            <a href="/" class="breadcrumb-link">Trang chủ</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Tin tức</span>
        </nav>
    </div>
</section>

<section class="news-section">
    <div class="custom-container">
        <div style="width: 100%;">

            <div class="news-filter-nav">
                <a href="/TinTuc" class="news-filter-pill @(ViewBag.CurrentCategory == null ? "active" : "")">
                    Tất cả bài viết
                </a>
                @if (ViewBag.DanhMucs != null)
                {
                    foreach (var dm in ViewBag.DanhMucs)
                    {
                        <a href="/TinTuc?maDanhMuc=@dm.MaDanhMuc" class="news-filter-pill @(ViewBag.CurrentCategory == dm.MaDanhMuc ? "active" : "")">
                            @dm.TenDanhMuc
                        </a>
                    }
                }
            </div>

            @if (allNews.Any())
            {
                @if (isShowFeatured)
                {
                    var mainNews = allNews[0];
                    var subNews1 = allNews[1];
                    var subNews2 = allNews[2];

                    <div class="news-featured-container">
                        <article class="featured-main">
                            <span class="featured-badge"><i class="fas fa-star text-warning"></i> NỔI BẬT</span>
                            <a href="/TinTuc/Details/@mainNews.MaTinTuc">
                                <img src="@mainNews.HinhAnhDaiDien" alt="@mainNews.TieuDe" />
                            </a>
                            <div class="featured-main-overlay">
                                <h3 class="news-name">
                                    <a href="/TinTuc/Details/@mainNews.MaTinTuc">@mainNews.TieuDe</a>
                                </h3>
                                <div class="news-meta">
                                    <i class="far fa-clock"></i> @mainNews.NgayDang?.ToString("dd/MM/yyyy HH:mm") &nbsp;|&nbsp;
                                    <i class="fas fa-folder-open"></i> @mainNews.DanhMucTin?.TenDanhMuc
                                </div>
                            </div>
                        </article>

                        <div class="featured-side">
                            <article class="featured-sub">
                                <a href="/TinTuc/Details/@subNews1.MaTinTuc" class="featured-sub-img">
                                    <img src="@subNews1.HinhAnhDaiDien" alt="@subNews1.TieuDe" />
                                </a>
                                <div class="featured-sub-info">
                                    <h3 class="news-name">
                                        <a href="/TinTuc/Details/@subNews1.MaTinTuc">@subNews1.TieuDe</a>
                                    </h3>
                                    <div class="news-meta" style="margin-bottom: 0;">
                                        <i class="far fa-clock"></i> @subNews1.NgayDang?.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                            </article>

                            <article class="featured-sub">
                                <a href="/TinTuc/Details/@subNews2.MaTinTuc" class="featured-sub-img">
                                    <img src="@subNews2.HinhAnhDaiDien" alt="@subNews2.TieuDe" />
                                </a>
                                <div class="featured-sub-info">
                                    <h3 class="news-name">
                                        <a href="/TinTuc/Details/@subNews2.MaTinTuc">@subNews2.TieuDe</a>
                                    </h3>
                                    <div class="news-meta" style="margin-bottom: 0;">
                                        <i class="far fa-clock"></i> @subNews2.NgayDang?.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                            </article>
                        </div>
                    </div>
                }

                <div class="news-grid">
                    @{
                        // Nếu có Tin nổi bật, bỏ qua 3 bài đầu. Nếu không, hiển thị toàn bộ
                        var gridNews = isShowFeatured ? allNews.Skip(3) : allNews;
                    }

                    @foreach (var item in gridNews)
                    {
                        <article class="news-card">
                            <div class="news-card-image">
                                <a href="/TinTuc/Details/@item.MaTinTuc">
                                    <img src="@item.HinhAnhDaiDien" alt="@item.TieuDe" />
                                </a>
                                <span class="news-badge-feature">
                                    <i class="fas fa-folder-open"></i> @item.DanhMucTin?.TenDanhMuc
                                </span>
                            </div>

                            <div class="news-card-body">
                                <div class="news-meta">
                                    <i class="fas fa-calendar-alt"></i> Ngày đăng: @item.NgayDang?.ToString("dd/MM/yyyy")
                                </div>

                                <h3 class="news-name">
                                    <a href="/TinTuc/Details/@item.MaTinTuc">@item.TieuDe</a>
                                </h3>

                                <p class="news-desc">
                                    @item.TomTat
                                </p>

                                <a href="/TinTuc/Details/@item.MaTinTuc" class="btn-read-now">ĐỌC TIẾP</a>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="empty-state-container">
                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" class="empty-icon" alt="Empty" />
                    <h4 class="empty-title">Chưa có bài viết nào!</h4>
                    <p class="empty-desc">Chúng tôi đang cập nhật thêm nội dung mới, vui lòng quay lại sau.</p>
                    <a href="/TinTuc" class="btn-back-home">XEM TẤT CẢ TIN</a>
                </div>
            }

        </div>
    </div>
</section>