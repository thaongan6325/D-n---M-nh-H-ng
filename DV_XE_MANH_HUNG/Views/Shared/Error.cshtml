@model Vivu_Xe.Models.ErrorViewModel

@{
    ViewData["Title"] = "Lỗi";
}

<h1 class="text-danger">Đã xảy ra lỗi.</h1>
<h2 class="text-danger">Hệ thống gặp sự cố khi xử lý yêu cầu của bạn.</h2>

@if (Model != null && Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Chế độ Phát triển (Development Mode)</h3>
<p>
    Việc chuyển sang môi trường <strong>Development</strong> sẽ hiển thị thông tin chi tiết hơn về lỗi.
</p>
<p>
    <strong>Không nên bật chế độ này khi đã triển khai thực tế (Deploy).</strong>
    Để bật chế độ này khi code local, hãy set biến môi trường <strong>ASPNETCORE_ENVIRONMENT</strong> thành <strong>Development</strong> và khởi động lại ứng dụng.
</p>