@model IEnumerable<Vivu_Xe.Models.DonDatXe>

@{
    ViewData["Title"] = "Chuyến đi của tôi";
    // Link file CSS riêng
    <link rel="stylesheet" href="~/css/history.css" />
    // Font Awesome cho icon
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="history-container">

    <div class="history-header">
        <h2 class="history-title"><i class="fas fa-history"></i> Lịch sử thuê xe</h2>
        <p class="history-desc">Quản lý các chuyến đi và trạng thái thanh toán của bạn.</p>
    </div>

    @if (Model.Count() == 0)
    {
        <div class="empty-state">
            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486747.png" class="empty-img" alt="Empty" />
            <h3>Bạn chưa có chuyến đi nào!</h3>
            <p>Hãy bắt đầu hành trình của bạn với Vivu Xe ngay hôm nay.</p>
            <a href="/" class="btn-home">Tìm xe ngay</a>
        </div>
    }
    else
    {
        <div class="booking-grid">
            @foreach (var item in Model)
            {
                // Xử lý logic class cho Badge
                string statusClass = "status-pending";
                string statusIcon = "fa-clock";

                if (item.TrangThaiDon == "Đã đặt cọc") { statusClass = "status-deposit"; statusIcon = "fa-check"; }
                else if (item.TrangThaiDon == "Đang đi") { statusClass = "status-active"; statusIcon = "fa-car"; }
                else if (item.TrangThaiDon == "Hoàn thành") { statusClass = "status-success"; statusIcon = "fa-flag-checkered"; }
                else if (item.TrangThaiDon == "Đã hủy") { statusClass = "status-cancel"; statusIcon = "fa-times"; }

                <div class="booking-card">
                    <div class="card-header">
                        <span class="order-id">#@item.MaDon</span>
                        <span class="status-badge @statusClass">
                            <i class="fas @statusIcon"></i> @item.TrangThaiDon
                        </span>
                    </div>

                    <div class="card-body">
                        <div class="car-image-wrapper">
                            @if (item.MaXeNavigation?.HinhAnhXes?.FirstOrDefault() != null)
                            {
                                <img src="@item.MaXeNavigation.HinhAnhXes.FirstOrDefault().DuongDan" class="car-image" alt="Xe">
                            }
                            else
                            {
                                <img src="/images/no-image.jpg" class="car-image" alt="No Image">
                            }
                        </div>

                        <h3 class="car-name">@item.MaXeNavigation?.TenXe</h3>
                        <span class="car-plate"><i class="fas fa-barcode"></i> @item.MaXeNavigation?.BienSo</span>

                        <div class="booking-info">
                            <span class="info-label">Ngày nhận:</span>
                            <span class="info-value">@item.NgayNhanDuKien.ToString("HH:mm dd/MM")</span>
                        </div>
                        <div class="booking-info">
                            <span class="info-label">Ngày trả:</span>
                            <span class="info-value">@item.NgayTraDuKien.ToString("HH:mm dd/MM")</span>
                        </div>

                        <hr class="divider">

                        <div class="total-price-row">
                            <span class="info-label">Tổng cộng:</span>
                            <span class="price-text">@string.Format("{0:N0}", item.TongTien) đ</span>
                        </div>
                    </div>

                    <div class="card-footer">
                        @if (item.TrangThaiDon == "Chờ thanh toán")
                        {
                            <a href="/Booking/Payment/@item.MaDon" class="btn-action btn-pay">
                                <i class="fas fa-credit-card"></i> Thanh toán ngay
                            </a>
                        }
                        else if (item.TrangThaiDon == "Hoàn thành")
                        {
                            <a href="/Xe/Details/@item.MaXe" class="btn-action btn-detail">
                                <i class="fas fa-eye"></i> Xem xe
                            </a>
                        }
                        else
                        {
                            // Các trạng thái khác (Đang đi, Đã hủy...) -> Nút chi tiết bị mờ hoặc link về chi tiết
                            <a href="/Xe/Details/@item.MaXe" class="btn-action btn-detail">
                                <i class="fas fa-eye"></i> Xem xe
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

