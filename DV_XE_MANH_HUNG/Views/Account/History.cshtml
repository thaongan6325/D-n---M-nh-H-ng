@model IEnumerable<Vivu_Xe.Models.DonDatXe>

@{
    ViewData["Title"] = "Chuyến đi của tôi";
    // Link file CSS riêng
    <link rel="stylesheet" href="~/css/history.css" />
    // Font Awesome cho icon
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}

<div class="history-container">

    <div class="history-header">
        <h2 class="history-title"><i class="fas fa-history"></i> Lịch sử thuê xe</h2>
        <p class="history-desc">Quản lý các chuyến đi và trạng thái thanh toán của bạn.</p>
    </div>

    @if (Model.Count() == 0)
    {
        <div class="empty-state">
            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486747.png" class="empty-img" alt="Empty" />
            <h3>Bạn chưa có chuyến đi nào!</h3>
            <p>Hãy bắt đầu hành trình của bạn với Vivu Xe ngay hôm nay.</p>
            <a href="/" class="btn-home">Tìm xe ngay</a>
        </div>
    }
    else
    {
        <div class="booking-grid">
            @foreach (var item in Model)
            {
                // Xử lý logic class cho Badge
                string statusClass = "status-pending";
                string statusIcon = "fa-clock";

                if (item.TrangThaiDon == "Đã đặt cọc") { statusClass = "status-deposit"; statusIcon = "fa-check"; }
                else if (item.TrangThaiDon == "Đang đi") { statusClass = "status-active"; statusIcon = "fa-car"; }
                else if (item.TrangThaiDon == "Hoàn thành") { statusClass = "status-success"; statusIcon = "fa-flag-checkered"; }
                else if (item.TrangThaiDon == "Đã hủy") { statusClass = "status-cancel"; statusIcon = "fa-times"; }

                <div class="booking-card">
                    <div class="card-header">
                        <span class="order-id">#@item.MaDon</span>
                        <span class="status-badge @statusClass">
                            <i class="fas @statusIcon"></i> @item.TrangThaiDon
                        </span>
                    </div>

                    <div class="card-body">
                        <div class="car-image-wrapper">
                            @if (item.MaXeNavigation?.HinhAnhXes?.FirstOrDefault() != null)
                            {
                                <img src="@item.MaXeNavigation.HinhAnhXes.FirstOrDefault().DuongDan" class="car-image" alt="Xe">
                            }
                            else
                            {
                                <img src="/images/no-image.jpg" class="car-image" alt="No Image">
                            }
                        </div>

                        <h3 class="car-name">@item.MaXeNavigation?.TenXe</h3>
                        <span class="car-plate"><i class="fas fa-barcode"></i> @item.MaXeNavigation?.BienSo</span>

                        <div class="booking-info">
                            <span class="info-label">Ngày nhận:</span>
                            <span class="info-value">@item.NgayNhanDuKien.ToString("HH:mm dd/MM")</span>
                        </div>
                        <div class="booking-info">
                            <span class="info-label">Ngày trả:</span>
                            <span class="info-value">@item.NgayTraDuKien.ToString("HH:mm dd/MM")</span>
                        </div>

                        <hr class="divider">

                        <div class="total-price-row">
                            <span class="info-label">Tổng cộng:</span>
                            <span class="price-text">@string.Format("{0:N0}", item.TongTien) đ</span>
                        </div>
                    </div>

                    <div class="card-footer">
                        @if (item.TrangThaiDon == "Chờ thanh toán")
                        {
                            <a href="/Booking/Payment/@item.MaDon" class="btn-action btn-pay">
                                <i class="fas fa-credit-card"></i> Thanh toán ngay
                            </a>
                        }
                        else if (item.TrangThaiDon == "Hoàn thành")
                        {
                            // Kiểm tra xem trong list DanhGias của đơn này có bản ghi nào không
                            bool daDanhGia = item.DanhGias != null && item.DanhGias.Any();

                            if (!daDanhGia)
                            {
                                // A. CHƯA ĐÁNH GIÁ -> Hiện nút Đánh giá (Mở Modal)
                                <button class="btn-action btn-rate"
                                        type="button"
                                        onclick="openReviewModal(@item.MaDon, @item.MaXe, '@Html.Raw(item.MaXeNavigation?.TenXe ?? "Xe")')">
                                    <i class="fas fa-star"></i> Đánh giá ngay
                                </button>
                            }
                            else
                            {
                                <a href="/Xe/Details/@item.MaXe" class="btn-action btn-done">
                                    <i class="fas fa-check-circle"></i> Đã đánh giá (Xem lại)
                                </a>
                            }
                        }
                        else
                        {
                            // Các trạng thái khác (Đang đi, Đã hủy...) -> Nút chi tiết bị mờ hoặc link về chi tiết
                            <a href="/Xe/Details/@item.MaXe" class="btn-action btn-detail">
                                <i class="fas fa-eye"></i> Xem xe
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
<div id="reviewModal" class="modal-overlay">
    <div class="modal-box">
        <span class="close-btn" onclick="closeReviewModal()">&times;</span>

        <h3 class="modal-title">Đánh giá chuyến đi</h3>
        <p id="modalXeName" style="color:#666; margin-bottom:20px;">Xe: ...</p>

        <form asp-action="GuiDanhGia" asp-controller="Xe" method="post">
            <input type="hidden" name="MaDon" id="inputMaDon" />
            <input type="hidden" name="MaXe" id="inputMaXe" />

            <div class="star-rating-input">
                <input type="radio" name="SoSao" id="star5" value="5" checked /><label for="star5" title="Tuyệt vời">★</label>
                <input type="radio" name="SoSao" id="star4" value="4" /><label for="star4" title="Tốt">★</label>
                <input type="radio" name="SoSao" id="star3" value="3" /><label for="star3" title="Tạm được">★</label>
                <input type="radio" name="SoSao" id="star2" value="2" /><label for="star2" title="Tệ">★</label>
                <input type="radio" name="SoSao" id="star1" value="1" /><label for="star1" title="Rất tệ">★</label>
            </div>

            <div class="form-group" style="margin-bottom:20px;">
                <textarea name="NhanXet" class="review-textarea" placeholder="Chia sẻ trải nghiệm của bạn về chiếc xe này..." required></textarea>
            </div>

            <button type="submit" class="btn-submit-review">Gửi Đánh Giá</button>
        </form>
    </div>
</div>
<script>
    // Hàm mở Modal
    function openReviewModal(maDon, maXe, tenXe) {

        // 1. Gán giá trị vào Input ẩn
        document.getElementById('inputMaDon').value = maDon;
        document.getElementById('inputMaXe').value = maXe;

        // 2. Hiện tên xe
        document.getElementById('modalXeName').innerText = "Xe: " + tenXe;

        // 3. Hiển thị Modal
        var modal = document.getElementById('reviewModal');
        if (modal) {
            modal.style.display = 'flex';
        } else {
            console.error("Không tìm thấy ID");
        }
    }

    // Hàm đóng Modal
    function closeReviewModal() {
        document.getElementById('reviewModal').style.display = 'none';
    }

    // Click ra ngoài thì tắt Modal
    window.onclick = function(event) {
        var modal = document.getElementById('reviewModal');
        if (event.target == modal) {
            modal.style.display = "none";
        }
    }
</script>