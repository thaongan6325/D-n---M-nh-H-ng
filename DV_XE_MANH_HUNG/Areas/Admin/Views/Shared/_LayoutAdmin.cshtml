@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị Vivu Xe</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/dashboard.css" rel="stylesheet">
    
</head>
<body>
    <div class="wrapper">
        <nav id="sidebar">
            <div class="sidebar-header">
                <h3>MANH HUNG </h3>
            </div>

            <ul class="list-unstyled components">

                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <a href="/Admin/Dashboard"><i class="fa-solid fa-chart-line me-2"></i> Thống kê</a>
                </li>
                
                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Xe" ? "active" : "")">
                    <a href="/Admin/Xe"><i class="fa-solid fa-car me-2"></i> Quản lý Xe</a>
                </li>

                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DonDatXe" ? "active" : "")">
                    <a href="/Admin/DonDatXe"><i class="fa-solid fa-file-contract me-2"></i> Đơn thuê xe</a>
                </li>

                <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "NguoiDung" ? "active" : "")">
                    <a href="/Admin/NguoiDung"><i class="fa-solid fa-users me-2"></i> Tài khoản</a>
                </li>
                

            </ul>
        </nav>

        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white rounded shadow-sm mb-4">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-primary">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <div class="ms-auto d-flex align-items-center">
                        <span class="me-3 text-muted">Xin chào,<strong>@HttpContextAccessor.HttpContext.Session.GetString("UserName")</strong></span>

                        <a asp-area="" asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">
                            <i class="fa-solid fa-right-from-bracket"></i> Thoát
                        </a>
                    </div>
                </div>
            </nav>

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarCollapse').addEventListener('click', function () {
            var sidebar = document.getElementById('sidebar');
            if (sidebar.style.marginLeft === '-250px') {
                sidebar.style.marginLeft = '0';
            } else {
                sidebar.style.marginLeft = '-250px';
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>