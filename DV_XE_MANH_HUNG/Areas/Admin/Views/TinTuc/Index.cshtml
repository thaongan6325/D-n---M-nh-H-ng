@model IEnumerable<Vivu_Xe.Models.TinTuc>

@{
    ViewData["Title"] = "Quản lý Bài viết";
    // Layout mặc định của Admin sẽ tự động được gọi
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Danh sách Bài viết</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Viết bài mới
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 90px;" class="text-center">Hình ảnh</th>
                        <th>Tiêu đề bài viết</th>
                        <th>Danh mục</th>
                        <th>Tác giả</th>
                        <th class="text-center">Lượt xem</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <img src="@item.HinhAnhDaiDien" alt="Thumbnail" style="width: 80px; height: 60px; object-fit: cover; border-radius: 4px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);" />
                                </td>
                                <td>
                                    <strong class="text-primary" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @item.TieuDe
                                    </strong>
                                    <small class="text-muted"><i class="fas fa-clock"></i> @item.NgayDang?.ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">@item.DanhMucTin?.TenDanhMuc</span>
                                </td>
                                <td>@item.TacGia?.HoTen</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">@item.LuotXem</span>
                                </td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-block">
                                        <!-- Gọi hàm JS để đổi trạng thái nhanh -->
                                        <input class="form-check-input" type="checkbox" role="switch"
                                               @(item.TrangThai == true ? "checked" : "")
                                               onclick="toggleStatus(@item.MaTinTuc)">
                                        <label class="form-check-label small">@(item.TrangThai == true ? "Xuất bản" : "Bản nháp")</label>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a href="/TinTuc/Details/@item.MaTinTuc" target="_blank" class="btn btn-sm btn-outline-info" title="Xem trước trên web">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaTinTuc" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="confirmDelete(@item.MaTinTuc)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Chưa có bài viết nào trong hệ thống!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- FORM ẨN ĐỂ XÓA DỮ LIỆU BẢO MẬT -->
<form id="deleteForm" method="post" asp-action="Delete">
    <input type="hidden" name="id" id="deleteId" />
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        // Hàm thay đổi trạng thái (Xuất bản / Bản nháp) bằng API
        function toggleStatus(id) {
            fetch(`/Admin/TinTuc/ToggleStatus/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    location.reload(); // Tải lại để cập nhật nhãn
                } else {
                    Swal.fire('Lỗi!', 'Không thể thay đổi trạng thái.', 'error');
                }
            })
            .catch(err => {
                // Nếu bạn chưa viết API ToggleStatus trong Controller thì có thể nó sẽ báo lỗi ở đây
                console.log("Cần viết thêm hàm ToggleStatus trong TinTucController", err);
            });
        }

        // Hàm gọi SweetAlert xác nhận xóa
        function confirmDelete(id) {
            Swal.fire({
                title: 'Bạn chắc chắn muốn xóa bài viết này?',
                text: "Dữ liệu sẽ bị xóa vĩnh viễn và không thể khôi phục!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            })
        }
    </script>
}