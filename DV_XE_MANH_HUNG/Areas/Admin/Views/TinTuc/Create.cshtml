@model Vivu_Xe.Models.TinTuc

@{
    ViewData["Title"] = "Đăng bài viết mới";
}

<style>
    .ck-editor__editable_inline {
        min-height: 400px;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Soạn Bài Viết Mới</h1>
        <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data" id="formTinTuc">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group mb-3">
                            <label asp-for="TieuDe" class="control-label fw-bold">Tiêu Đề Bài Viết</label>
                            <input asp-for="TieuDe" class="form-control" placeholder="Nhập tiêu đề thật hấp dẫn..." required />
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="TomTat" class="control-label fw-bold">Tóm Tắt (Mô tả ngắn)</label>
                            <textarea asp-for="TomTat" class="form-control" rows="3" placeholder="Đoạn văn ngắn hiển thị ở ngoài trang chủ..."></textarea>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="NoiDung" class="control-label fw-bold text-primary">
                                <i class="fas fa-edit"></i> Nội Dung Bài Viết
                            </label>
                            <textarea asp-for="NoiDung" id="editor" class="form-control"></textarea>
                            <span asp-validation-for="NoiDung" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="MaDanhMuc" class="control-label fw-bold">Danh Mục</label>
                            <select asp-for="MaDanhMuc" class="form-control" asp-items="ViewBag.MaDanhMuc">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="TrangThai" class="control-label fw-bold">Trạng Thái</label>
                            <select asp-for="TrangThai" class="form-control">
                                <option value="true">Xuất bản ngay</option>
                                <option value="false">Lưu nháp</option>
                            </select>
                        </div>

                        <div class="form-group mb-3 p-3 bg-light border rounded">
                            <label class="control-label fw-bold">
                                <i class="fas fa-image"></i> Ảnh Đại Diện (Thumbnail)
                            </label>
                            <input type="file" name="HinhAnhDaiDien" accept="image/*" class="form-control mt-2" required />
                        </div>

                        <hr />
                        <button type="submit" formnovalidate class="btn btn-primary btn-lg w-100 mt-2 shadow">
                            <i class="fas fa-paper-plane"></i> ĐĂNG BÀI
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/super-build/ckeditor.js"></script>

    <script>
        // MỚI: Khai báo biến toàn cục để hứng đối tượng CKEditor
        let myEditor;

        // Bắt buộc đợi HTML load xong 100% mới chạy Script
        document.addEventListener("DOMContentLoaded", function () {

            // 1. Kiểm tra xem thẻ textarea có tồn tại không
            const editorElement = document.querySelector('#editor');
            if (!editorElement) {
                console.error('Không tìm thấy thẻ có id="editor"');
                return;
            }

            // 2. Viết Adapter upload ảnh
            class MyUploadAdapter {
                constructor(loader) {
                    this.loader = loader;
                }

                upload() {
                    return this.loader.file
                        .then(file => new Promise((resolve, reject) => {
                            const data = new FormData();
                            data.append('upload', file);

                            fetch('/Admin/TinTuc/UploadImageCKEditor', {
                                method: 'POST',
                                body: data
                            })
                            .then(response => response.json())
                            .then(result => {
                                if (result.uploaded) {
                                    resolve({ default: result.url });
                                } else {
                                    reject(result.error ? result.error.message : 'Upload thất bại');
                                }
                            })
                            .catch(error => {
                                reject('Lỗi kết nối tới Server');
                            });
                        }));
                }
                abort() {}
            }

            function MyCustomUploadAdapterPlugin(editor) {
                editor.plugins.get('FileRepository').createUploadAdapter = (loader) => {
                    return new MyUploadAdapter(loader);
                };
            }

            // 3. Khởi tạo CKEditor Super Build
            if (typeof CKEDITOR !== 'undefined' && CKEDITOR.ClassicEditor) {
                CKEDITOR.ClassicEditor.create(editorElement, {
                    extraPlugins: [MyCustomUploadAdapterPlugin],
                    removePlugins: [
                        'RealTimeCollaborativeComments',
                        'RealTimeCollaborativeTrackChanges',
                        'RealTimeCollaborativeRevisionHistory',
                        'PresenceList',
                        'Comments',
                        'TrackChanges',
                        'TrackChangesData',
                        'RevisionHistory',
                        'Pagination',
                        'WProofreader',
                        'MathType',
                        'ExportPdf',
                        'ExportWord',
                        'ImportWord',
                        'CKBox',
                        'CKFinder',
                        'EasyImage',
                        'Base64UploadAdapter',
                        'DocumentOutline',
                        'FormatPainter',
                        'PasteFromOfficeEnhanced',
                        'SlashCommand',
                        'Template',
                        'TableOfContents'
                    ],
                    toolbar: {
                        items: [
                            'heading', '|',
                            'bold', 'italic', 'underline', 'strikethrough', '|',
                            'alignment', '|',
                            'fontColor', 'fontBackgroundColor', '|',
                            'bulletedList', 'numberedList', '|',
                            'imageUpload', 'insertTable', 'mediaEmbed', 'link', '|',
                            'undo', 'redo'
                        ],
                        shouldNotGroupWhenFull: true
                    },
                    alignment: {
                        options: [ 'left', 'center', 'right', 'justify' ]
                    }
                })
                .then(editor => {
                    // MỚI: Gán editor vào biến toàn cục myEditor
                    myEditor = editor;
                    console.log('CKEditor đã khởi tạo thành công!');
                })
                .catch(error => {
                    console.error('Lỗi khi khởi tạo CKEditor:', error);
                });
            } else {
                console.error('Thư viện CKEditor chưa được tải thành công từ CDN.');
            }

            // MỚI: Bắt sự kiện khi bấm nút ĐĂNG BÀI
            document.getElementById('formTinTuc').addEventListener('submit', function(e) {
                if (myEditor) {
                    // Cập nhật nội dung từ CKEditor ngược lại vào thẻ <textarea id="editor"> đang bị ẩn
                    document.querySelector('#editor').value = myEditor.getData();
                }
            });
        });
    </script>
}