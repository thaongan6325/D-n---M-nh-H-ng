@model IEnumerable<Vivu_Xe.Models.Xe>

@{
    ViewData["Title"] = "Quản lý Đội xe";
}

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="m-0 font-weight-bold text-primary"><i class="fa-solid fa-car"></i> Danh sách Xe</h5>
        <a asp-action="Create" class="btn btn-primary btn-sm shadow-sm">
            <i class="fa-solid fa-plus"></i> Thêm xe mới
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light text-center">
                    <tr>
                        <th>Tên Xe</th>
                        <th>Biển Số</th>
                        <th>Hãng / Loại</th>
                        <th>Giá Thuê</th>
                        <th>Cọc</th>
                        <th>Trạng Thái</th>
                        <th width="150">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@Html.DisplayFor(modelItem => item.TenXe)</td>
                            <td><span class="badge bg-secondary">@Html.DisplayFor(modelItem => item.BienSo)</span></td>
                            <td>
                                @Html.DisplayFor(modelItem => item.MaHangNavigation.TenHang) <br />
                                <small class="text-muted">@Html.DisplayFor(modelItem => item.MaLoaiNavigation.TenLoai)</small>
                            </td>
                            <td class="text-end text-success fw-bold">
                                @item.GiaThueNgay.ToString("N0") đ
                            </td>
                            <td class="text-end">
                                @(item.TienCoc?.ToString("N0") ?? "0") đ
                            </td>
                            <td class="text-center">
                                @if (item.TrangThai == "SanSang")
                                {
                                    <span class="badge bg-success"><i class="fa-solid fa-check"></i> Sẵn sàng</span>
                                }
                                else if (item.TrangThai == "DangThue")
                                {
                                    <span class="badge bg-warning text-dark"><i class="fa-solid fa-road"></i> Đang thuê</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="fa-solid fa-wrench"></i> @item.TrangThai</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.MaXe" class="btn btn-warning btn-sm" title="Sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.MaXe" class="btn btn-info btn-sm text-white" title="Chi tiết">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.MaXe" class="btn btn-danger btn-sm" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>