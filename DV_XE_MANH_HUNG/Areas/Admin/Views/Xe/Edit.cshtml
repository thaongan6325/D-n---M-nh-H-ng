@model Vivu_Xe.Models.Xe

@{
    ViewData["Title"] = "Cập nhật Xe";
}

<div class="container-fluid">

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            Sửa thông tin xe:
            <span class="text-primary">@Model.TenXe</span>
        </h1>

        <a asp-action="Index"
           class="btn btn-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left"></i>
            Quay lại
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">

            <form asp-action="Edit"
                  method="post"
                  enctype="multipart/form-data"
                  novalidate>

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <input type="hidden" asp-for="MaXe" />
                <input type="hidden" asp-for="NgayTao" />

                <div class="row">

                    <!-- CỘT TRÁI -->
                    <div class="col-md-6">

                        <div class="form-group mb-3">
                            <label asp-for="TenXe"
                                   class="control-label fw-bold">
                                Tên Xe
                            </label>

                            <input asp-for="TenXe"
                                   class="form-control" />

                            <span asp-validation-for="TenXe"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="BienSo"
                                   class="control-label fw-bold">
                                Biển Số
                            </label>

                            <input asp-for="BienSo"
                                   class="form-control" />

                            <span asp-validation-for="BienSo"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="MaHang"
                                   class="control-label fw-bold">
                                Hãng Xe
                            </label>

                            <select asp-for="MaHang"
                                    class="form-control"
                                    asp-items="ViewBag.MaHang">
                                <option value="">-- Chọn hãng xe --</option>
                            </select>

                            <span asp-validation-for="MaHang"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="MaLoai"
                                   class="control-label fw-bold">
                                Loại Xe
                            </label>

                            <select asp-for="MaLoai"
                                    class="form-control"
                                    asp-items="ViewBag.MaLoai">
                                <option value="">-- Chọn loại xe --</option>
                            </select>

                            <span asp-validation-for="MaLoai"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="row">

                            <div class="col-6 form-group mb-3">
                                <label asp-for="MauSac"
                                       class="control-label fw-bold">
                                    Màu Sắc
                                </label>

                                <input asp-for="MauSac"
                                       class="form-control"
                                       placeholder="VD: Trắng" />

                                <span asp-validation-for="MauSac"
                                      class="text-danger">
                                </span>
                            </div>

                            <div class="col-6 form-group mb-3">
                                <label asp-for="NamSanXuat"
                                       class="control-label fw-bold">
                                    Năm Sản Xuất
                                </label>

                                <input asp-for="NamSanXuat"
                                       type="number"
                                       class="form-control"
                                       placeholder="VD: 2024" />

                                <span asp-validation-for="NamSanXuat"
                                      class="text-danger">
                                </span>
                            </div>

                        </div>
                    </div>

                    <!-- CỘT PHẢI -->
                    <div class="col-md-6">

                        <div class="row">

                            <div class="col-6 form-group mb-3">
                                <label asp-for="HopSo"
                                       class="control-label fw-bold">
                                    Hộp Số
                                </label>

                                <select asp-for="HopSo"
                                        class="form-control">
                                    <option value="">-- Chọn hộp số --</option>
                                    <option value="Tự động">Tự động</option>
                                    <option value="Số sàn">Số sàn</option>
                                </select>

                                <span asp-validation-for="HopSo"
                                      class="text-danger">
                                </span>
                            </div>

                            <div class="col-6 form-group mb-3">
                                <label asp-for="NhienLieu"
                                       class="control-label fw-bold">
                                    Nhiên Liệu
                                </label>

                                <select asp-for="NhienLieu"
                                        class="form-control">
                                    <option value="">-- Chọn nhiên liệu --</option>
                                    <option value="Xăng">Xăng</option>
                                    <option value="Dầu">Dầu (Diesel)</option>
                                    <option value="Điện">Điện</option>
                                </select>

                                <span asp-validation-for="NhienLieu"
                                      class="text-danger">
                                </span>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-6 form-group mb-3">
                                <label asp-for="GiaThueNgay"
                                       class="control-label fw-bold">
                                    Giá Thuê/Ngày
                                </label>

                                <input asp-for="GiaThueNgay"
                                       type="number"
                                       class="form-control" />

                                <span asp-validation-for="GiaThueNgay"
                                      class="text-danger">
                                </span>
                            </div>

                            <div class="col-6 form-group mb-3">
                                <label asp-for="TienCoc"
                                       class="control-label fw-bold">
                                    Tiền Cọc
                                </label>

                                <input asp-for="TienCoc"
                                       type="number"
                                       class="form-control" />

                                <span asp-validation-for="TienCoc"
                                      class="text-danger">
                                </span>
                            </div>

                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="TrangThai"
                                   class="control-label fw-bold">
                                Trạng Thái
                            </label>

                            <select asp-for="TrangThai"
                                    class="form-control">
                                <option value="">-- Chọn trạng thái --</option>
                                <option value="Sẵn sàng">
                                    Sẵn sàng (Cho thuê)
                                </option>
                                <option value="Đang thuê">
                                    Đang thuê
                                </option>
                                <option value="Bảo dưỡng">
                                    Bảo dưỡng
                                </option>
                                <option value="Ngưng hoạt động">
                                    Ngưng hoạt động
                                </option>
                            </select>

                            <span asp-validation-for="TrangThai"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="form-group mb-3 p-3 bg-light border rounded">

                            <label class="control-label fw-bold text-success">
                                <i class="fas fa-plus-circle"></i>
                                Tải thêm ảnh mới
                            </label>

                            <input type="file"
                                   name="uploadHinhAnhs"
                                   multiple
                                   accept="image/*"
                                   class="form-control" />

                            @if (ViewData.ModelState["uploadHinhAnhs"]?.Errors.Count > 0)
                            {
                                foreach (var error in ViewData.ModelState["uploadHinhAnhs"]!.Errors)
                                {
                                    <div class="text-danger mt-1">
                                        @error.ErrorMessage
                                    </div>
                                }
                            }

                        </div>
                    </div>

                </div>

                <div class="form-group mb-4">
                    <label asp-for="MoTa"
                           class="control-label fw-bold">
                        Mô Tả Chi Tiết
                    </label>

                    <textarea asp-for="MoTa"
                              class="form-control"
                              rows="4"
                              maxlength="1000"
                              placeholder="Nhập mô tả chi tiết về xe..."></textarea>

                    <span asp-validation-for="MoTa"
                          class="text-danger">
                    </span>
                </div>

                <div class="form-group mb-4">

                    <label class="control-label fw-bold">
                        <i class="fas fa-images"></i>
                        Các hình ảnh hiện tại
                    </label>

                    <div class="row" id="current-images">

                        @if (Model.HinhAnhXes != null &&
                                                Model.HinhAnhXes.Any())
                        {
                            foreach (var item in Model.HinhAnhXes)
                            {
                                <div class="col-md-2 col-sm-4 mb-3 position-relative"
                                     id="img-box-@item.MaHinh">

                                    <img src="@item.DuongDan"
                                         alt="Hình ảnh xe"
                                         class="img-thumbnail"
                                         style="width:100%; height:120px; object-fit:cover;" />

                                    <button type="button"
                                            class="btn btn-danger btn-sm position-absolute"
                                            style="top:5px; right:20px;"
                                            onclick="deleteImage(@item.MaHinh)">
                                        <i class="fas fa-trash"></i>
                                    </button>

                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12" id="no-images-message">
                                <p class="text-muted fst-italic">
                                    Chưa có hình ảnh nào.
                                </p>
                            </div>
                        }

                    </div>
                </div>

                <hr />

                <div class="form-group text-center">
                    <button type="submit"
                            class="btn btn-primary btn-lg px-5">
                        <i class="fas fa-save"></i>
                        Cập Nhật Dữ Liệu
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function deleteImage(imgId) {
            Swal.fire({
                title: 'Bạn có chắc chắn?',
                text: 'Ảnh sẽ bị xóa vĩnh viễn khỏi hệ thống!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {

                if (!result.isConfirmed) {
                    return;
                }

                const tokenInput =
                    document.querySelector(
                        'input[name="__RequestVerificationToken"]'
                    );

                fetch(`/Admin/Xe/DeleteImage/${imgId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken':
                            tokenInput ? tokenInput.value : ''
                    }
                })
                .then(async response => {
                    const data = await response.json();

                    if (!response.ok) {
                        throw new Error(
                            data.message || 'Không thể xóa ảnh.'
                        );
                    }

                    return data;
                })
                .then(data => {
                    if (!data.success) {
                        throw new Error(
                            data.message || 'Không thể xóa ảnh.'
                        );
                    }

                    const imageBox =
                        document.getElementById(
                            `img-box-${imgId}`
                        );

                    if (imageBox) {
                        imageBox.remove();
                    }

                    const remainingImages =
                        document.querySelectorAll(
                            '[id^="img-box-"]'
                        );

                    if (remainingImages.length === 0) {
                        const imageContainer =
                            document.getElementById(
                                'current-images'
                            );

                        imageContainer.innerHTML = `
                            <div class="col-12"
                                 id="no-images-message">
                                <p class="text-muted fst-italic">
                                    Chưa có hình ảnh nào.
                                </p>
                            </div>
                        `;
                    }

                    Swal.fire(
                        'Đã xóa!',
                        'Hình ảnh đã được xóa thành công.',
                        'success'
                    );
                })
                .catch(error => {
                    Swal.fire(
                        'Lỗi!',
                        error.message ||
                        'Đã xảy ra lỗi hệ thống.',
                        'error'
                    );
                });
            });
        }
    </script>
}