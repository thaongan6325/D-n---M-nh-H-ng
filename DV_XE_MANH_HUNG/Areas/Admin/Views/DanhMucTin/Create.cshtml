@model Vivu_Xe.Models.DanhMucTin

@{
    ViewData["Title"] = "Thêm Danh mục mới";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Thêm Danh Mục</h1>
    <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow mb-4">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group mb-3">
                        <label asp-for="TenDanhMuc" class="control-label fw-bold">Tên Danh Mục</label>
                        <input asp-for="TenDanhMuc" class="form-control" required placeholder="VD: Review xe, Cẩm nang..." />
                        <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="MoTa" class="control-label fw-bold">Mô tả ngắn</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save"></i> Lưu Dữ Liệu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}